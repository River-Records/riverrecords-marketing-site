---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

// Comparison guides live in the blog collection, tagged "comparisons".
const guides = (await getCollection('blog', ({ data }) =>
  !data.draft && data.tags.includes('comparisons')))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

// Curated head-to-head pages that live outside the blog collection.
const headToHead = [
  {
    href: '/comparison/freedai',
    title: 'Stream vs. Freed',
    description: 'A direct, feature-by-feature look at how Stream and Freed compare for primary care documentation.',
    label: 'Head-to-head',
  },
];
---
<Page
  title="AI Medical Scribe Comparisons & Buying Guides — Stream by River Records"
  description="Honest comparisons of AI medical scribes for independent primary care — by price, note structure, EHR handoff, and workflow fit. Including where competitors are the better choice.">

<style>
.cmp-hero {
  padding: 72px 0 48px;
}
.cmp-hero h1 {
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--ink);
  margin-bottom: 10px;
}
.cmp-hero p {
  font-size: 1.05rem;
  color: var(--ink-muted);
  max-width: 600px;
  line-height: 1.6;
}
.cmp-grid {
  padding: 0 0 88px;
}
.cmp-section-label {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ink-faint);
  margin-bottom: 20px;
}
.cmp-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 48px;
}
.cmp-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: box-shadow 0.15s, transform 0.15s;
  display: flex;
  flex-direction: column;
  text-decoration: none;
}
.cmp-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.cmp-card-body {
  padding: 22px;
  flex: 1;
  display: flex;
  flex-direction: column;
}
.cmp-card-tag {
  font-size: 0.67rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: var(--r-pill);
  background: var(--primary-light);
  color: var(--primary);
  align-self: flex-start;
  margin-bottom: 10px;
}
.cmp-card h2 {
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.35;
  margin-bottom: 8px;
  font-family: var(--font-sans);
}
.cmp-card p {
  font-size: 0.855rem;
  color: var(--ink-muted);
  line-height: 1.55;
  margin-bottom: 14px;
  flex: 1;
}
.cmp-card-meta {
  font-size: 0.76rem;
  color: var(--ink-faint);
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: auto;
}
.cmp-card-meta-dot {
  width: 3px; height: 3px;
  border-radius: 50%;
  background: var(--border-strong);
}
.cmp-disclosure {
  font-size: 0.82rem;
  color: var(--ink-faint);
  line-height: 1.6;
  max-width: 640px;
  border-top: 1px solid var(--border);
  padding-top: 20px;
}

@media (max-width: 900px) {
  .cmp-list { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .cmp-list { grid-template-columns: 1fr; }
}
</style>

<section class="cmp-hero">
  <div class="container">
    <span class="section-label">Comparisons</span>
    <h1>AI scribe comparisons & buying guides.</h1>
    <p>Honest, practitioner-focused comparisons of the AI medical scribes built for independent primary care — by price, note structure, EHR handoff, and workflow fit. We make Stream, and we'll tell you where a competitor is the better choice.</p>
  </div>
</section>

<section class="cmp-grid">
  <div class="container">

    {headToHead.length > 0 && (
      <>
        <div class="cmp-section-label">Head-to-head</div>
        <div class="cmp-list">
          {headToHead.map((item) => (
            <a href={item.href} class="cmp-card">
              <div class="cmp-card-body">
                <span class="cmp-card-tag">{item.label}</span>
                <h2>{item.title}</h2>
                <p>{item.description}</p>
              </div>
            </a>
          ))}
        </div>
      </>
    )}

    {guides.length > 0 && (
      <>
        <div class="cmp-section-label">Buying guides</div>
        <div class="cmp-list">
          {guides.map((post) => {
            const dateStr = new Date(post.data.publishDate).toLocaleDateString('en-US', {
              year: 'numeric', month: 'short', day: 'numeric',
            });
            return (
              <a href={`/blog/${post.id}`} class="cmp-card">
                <div class="cmp-card-body">
                  <span class="cmp-card-tag">Guide</span>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.description}</p>
                  <div class="cmp-card-meta">
                    <span>{post.data.author}</span>
                    <div class="cmp-card-meta-dot"></div>
                    <span>{dateStr}</span>
                    {post.data.readTime && (
                      <>
                        <div class="cmp-card-meta-dot"></div>
                        <span>{post.data.readTime} min</span>
                      </>
                    )}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </>
    )}

    <p class="cmp-disclosure">
      These guides are published by River Records, the maker of Stream. We aim to represent every tool fairly, including where competitors are the better fit. Pricing and features change frequently — verify current details on each vendor's own site before deciding.
    </p>

  </div>
</section>

</Page>
