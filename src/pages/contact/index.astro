---
import Page from '../../layouts/Page.astro';
---
<Page
  title="Contact — Stream by River Records"
  description="Have a question or need help? Reach out to the River Records team.">

<Fragment slot="head">
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact River Records",
    "description": "Have a question or need help? Reach out to the River Records team.",
    "mainEntity": {
      "@type": "Organization",
      "name": "River Records",
      "email": "hello@riverrecords.ai",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "16192 Coastal Highway",
        "addressLocality": "Lewes",
        "addressRegion": "DE",
        "postalCode": "19958",
        "addressCountry": "US"
      },
      "telephone": "+1-508-906-7179"
    }
  }
  </script>
</Fragment>

<style>
.contact-section {
  padding: 88px 0 72px;
  text-align: center;
}
.contact-section h1 {
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--ink);
  margin-bottom: 12px;
}
.contact-sub {
  font-size: 1.1rem;
  color: var(--ink-muted);
  line-height: 1.6;
  max-width: 480px;
  margin: 0 auto 40px;
}
.contact-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-md);
  padding: 40px;
  max-width: 520px;
  margin: 0 auto;
  text-align: left;
}
.contact-form label {
  display: block;
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 6px;
}
.contact-form input,
.contact-form textarea {
  width: 100%;
  padding: 10px 14px;
  font-size: 0.925rem;
  font-family: var(--font-sans);
  border: 1px solid var(--border-strong);
  border-radius: var(--r-md);
  background: var(--white);
  color: var(--ink);
  outline: none;
  transition: border-color 0.15s;
  margin-bottom: 18px;
}
.contact-form input:focus,
.contact-form textarea:focus {
  border-color: var(--primary);
}
.contact-form textarea {
  min-height: 120px;
  resize: vertical;
}
.contact-form input::placeholder,
.contact-form textarea::placeholder {
  color: var(--ink-faint);
}
.contact-email-line {
  font-size: 0.84rem;
  color: var(--ink-faint);
  text-align: center;
  margin-top: 20px;
}
.contact-email-line a {
  color: var(--primary);
  text-decoration: none;
  font-weight: 500;
}
.contact-email-line a:hover { text-decoration: underline; }
</style>

<section class="contact-section">
  <div class="container">
    <span class="section-label">Contact</span>
    <h1>We'd love to hear from you.</h1>
    <p class="contact-sub">Have a question about Stream, need help with your account, or want to discuss pricing for your practice? We respond within one business day.</p>

    <div class="contact-card">
      <form class="contact-form" action="https://formsubmit.co/hello@riverrecords.ai" method="POST">
        <input type="hidden" name="_next" value="https://www.riverrecords.ai/contacted">
        <input type="hidden" name="_subject" value="New contact from riverrecords.ai">
        <input type="hidden" name="_captcha" value="false">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" placeholder="Your name" required>
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@practice.com" required>
        <label for="message">Message</label>
        <textarea id="message" name="message" placeholder="How can we help?" required></textarea>
        <button type="submit" class="btn btn-primary-lg" style="width:100%;display:block;text-align:center;">Send Message</button>
      </form>
      <p class="contact-email-line">Or email us directly at <a href="mailto:hello@riverrecords.ai">hello@riverrecords.ai</a></p>
    </div>
  </div>
</section>

</Page>
