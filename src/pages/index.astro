<script is:inline>
// FAQ toggle
function toggleFaq(item) {
  const open = item.classList.contains('open');
  document.querySelectorAll('.home-faq-item').forEach(i => {
    i.classList.remove('open');
    i.querySelector('.home-faq-icon').textContent = '+';
  });
  if (!open) {
    item.classList.add('open');
    item.querySelector('.home-faq-icon').textContent = '\u2212';
  }
}
document.querySelectorAll('.home-faq-item').forEach(item => {
  item.addEventListener('click', () => toggleFaq(item));
});

// Scroll reveal
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }});
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.hr').forEach(el => obs.observe(el));
</script>

