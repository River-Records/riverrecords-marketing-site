---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HuddleDemo from '../components/demos/HuddleDemo.vue';
import EncounterViewDemo from '../components/demos/EncounterViewDemo.vue';
import TimelineRecapDemo from '../components/demos/TimelineRecapDemo.vue';
import { pricing } from '../config/pricing';
import { stats } from '../config/stats';

const utmBase = '?utm_source=homepage&utm_medium=landing&utm_campaign=home-v2';
const onboardUrl = `https://stream.riverrecords.ai/onboard/stream-pro${utmBase}`;
const jamaUrl = 'https://jamanetwork.com/journals/jamanetworkopen/fullarticle/2796664';

// Clinic logo strip — flip to true and fill in logo files once assets land
const SHOW_CLINIC_LOGOS = false;
const clinicLogos = [
  // { src: '/images/clinics/example.png', alt: 'Example Family Medicine' },
];

// Metrics bar — entries whose stat is null in src/config/stats.ts are hidden
const metricItems = [
  stats.noteMinutes ? { value: `${stats.noteMinutes} min`, label: 'average time to complete a note' } : null,
  { value: `${stats.encounters}+`, label: 'patient encounters documented and organized' },
  stats.retention90 ? { value: `${stats.retention90}%`, label: 'of users still active after 90 days' } : null,
].filter(Boolean);
---
<Base
  title="Stream — AI Medical Scribe with Memory | Problem-Based Notes"
  description="Stream is your AI scribe and clinical assistant — organized by medical problem, not by date. Faster notes today. A smarter chart tomorrow. 30-day free trial.">

  <Fragment slot="head">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Stream by River Records",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web",
      "description": "AI medical scribe with memory. Problem-based clinical notes for primary care, SNF, and long-term care.",
      "offers": { "@type": "Offer", "price": "149", "priceCurrency": "USD" }
    }
    </script>
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Can I use Stream with my existing EHR?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Stream works alongside any EHR. You copy your note into your EHR, or use Stream as your standalone documentation layer. Native integrations are in development for Elation first, then Athena." }},
        { "@type": "Question", "name": "Is Stream HIPAA compliant?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Fully HIPAA compliant. BAA with every subscriber. Encrypted at rest and in transit. We never train our models on your patient data." }},
        { "@type": "Question", "name": "What security measures does Stream have beyond HIPAA?", "acceptedAnswer": { "@type": "Answer", "text": "All data is encrypted at rest and in transit. Audit controls and access logging are in place across the platform. We sign a Business Associate Agreement (BAA) with every subscriber, and we never train our models on your patient data." }}
      ]
    }
    </script>
  </Fragment>

<style>
/* ── HOMEPAGE V2 ──────────────────────────── */
.home {
  --ink: #0f1a14;
  --ink-soft: #2a3a32;
  --ink-mute: #566b60;
  --paper: #f5f1e8;
  --paper-warm: #ede6d3;
  --cream: #faf7f0;
  --stream: #1e5a3e;
  --stream-dark: #0f3a26;
  --stream-light: #e8f0ea;
  --accent: #c9563f;
  --accent-soft: #e87a61;
  --rule: rgba(15, 26, 20, 0.12);
  --rule-strong: rgba(15, 26, 20, 0.25);
  font-family: 'Inter Tight', system-ui, sans-serif;
  color: var(--ink);
  background: var(--cream);
}
.home h1, .home h2, .home h3 { font-family: 'Fraunces', Georgia, serif; }
.hc { max-width: 1100px; margin: 0 auto; padding: 0 28px; }

/* Labels */
.hl { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-mute); margin-bottom: 16px; }

/* Announcement bar */
.home-announce { background: var(--stream-dark); color: var(--cream); text-align: center; padding: 10px 24px; font-size: 0.82rem; font-weight: 500; }
.home-announce strong { color: var(--accent-soft); }
.home-announce a { color: var(--accent-soft); text-decoration: underline; text-underline-offset: 2px; margin-left: 8px; }

/* Buttons */
.hb-primary { display: inline-flex; align-items: center; gap: 6px; background: var(--stream-dark); color: var(--cream); padding: 12px 24px; border-radius: 100px; font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: background 0.15s; font-family: 'Inter Tight', system-ui, sans-serif; }
.hb-primary:hover { background: var(--stream); }
.hb-secondary { display: inline-flex; align-items: center; gap: 6px; background: none; color: var(--ink-soft); padding: 12px 24px; border-radius: 100px; border: 1.5px solid var(--rule-strong); font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: border-color 0.15s, color 0.15s; font-family: 'Inter Tight', system-ui, sans-serif; }
.hb-secondary:hover { border-color: var(--stream); color: var(--stream); }
.hb-accent { display: inline-flex; align-items: center; gap: 6px; background: var(--accent); color: var(--cream); padding: 12px 24px; border-radius: 100px; font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: background 0.15s; font-family: 'Inter Tight', system-ui, sans-serif; }
.hb-accent:hover { background: var(--accent-soft); }

/* Demo frame */
.demo-frame { position: relative; background: var(--cream); border: 1px solid var(--rule); border-radius: 16px; padding: 8px; box-shadow: 0 8px 24px rgba(15,26,20,0.10), 0 24px 60px rgba(15,26,20,0.08); font-family: 'Inter', system-ui, sans-serif; }
.demo-frame__label { position: absolute; top: -12px; left: 20px; background: var(--accent); color: var(--cream); font-family: 'JetBrains Mono', monospace; font-size: 0.66rem; letter-spacing: 0.1em; padding: 4px 10px; border-radius: 100px; font-weight: 600; z-index: 2; }

/* Reveal */
.hr { opacity: 0; transform: translateY(24px); transition: opacity 0.4s ease-out, transform 0.4s ease-out; }
.hr.visible { opacity: 1; transform: translateY(0); }

/* === HERO === */
.home-hero { padding: 72px 0 56px; }
.home-hero-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: 48px; align-items: center; }
.home-eyebrow { display: inline-flex; align-items: center; gap: 8px; background: var(--stream-light); color: var(--stream); border-radius: 100px; padding: 6px 16px; font-size: 0.78rem; font-weight: 600; margin-bottom: 24px; }
.home-eyebrow::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--stream); animation: pulse-dot 2s ease-in-out infinite; }
@keyframes pulse-dot { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
.home-hero h1 { font-size: clamp(2.2rem, 4vw, 2.8rem); line-height: 1.15; color: var(--ink); margin-bottom: 18px; max-width: 480px; }
.home-hero h1 em { font-style: italic; color: var(--stream); }
.home-hero-sub { font-size: 1.05rem; color: var(--ink-soft); line-height: 1.65; margin-bottom: 28px; max-width: 520px; }
.home-cta-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 18px; }
.home-trust { font-size: 0.77rem; color: var(--ink-mute); display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.home-trust span { display: flex; align-items: center; gap: 4px; }
.home-trust span::before { content: '✓'; color: var(--stream); font-weight: 700; }


/* === THESIS === */
.home-thesis { padding: 80px 0; background: var(--cream); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
.home-thesis h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); color: var(--ink); margin-bottom: 14px; text-align: center; max-width: 760px; margin-left: auto; margin-right: auto; }
.home-thesis h2 em { font-style: italic; color: var(--stream); }
.home-thesis-lede { font-size: 1.05rem; color: var(--ink-soft); line-height: 1.65; max-width: 680px; margin: 0 auto 40px; text-align: center; }
.home-thesis-lede a { color: var(--stream); text-decoration: underline; text-underline-offset: 2px; }
.home-thesis-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.home-thesis-card { border-radius: 16px; padding: 32px; border: 1px solid var(--rule); }
.home-thesis-card--muted { background: var(--paper); }
.home-thesis-card--stream { background: var(--stream-light); }
.home-thesis-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-mute); margin-bottom: 12px; }
.home-thesis-card h3 { font-size: 1.3rem; color: var(--ink); margin-bottom: 14px; }
.home-thesis-card h3 em { font-style: italic; color: var(--stream); }
.home-thesis-card p { font-size: 0.925rem; color: var(--ink-soft); line-height: 1.6; }
.home-thesis-card strong { color: var(--ink); }

/* === CLINIC LOGOS (label + specialties always; logo row appears when assets land) === */
.home-logos { padding: 18px 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
.home-logos-label { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-mute); text-align: center; margin-bottom: 6px; }
.home-logos-specialties { font-family: 'Fraunces', Georgia, serif; font-size: 0.95rem; color: var(--ink-soft); text-align: center; }
.home-logos-row { display: flex; align-items: center; justify-content: center; gap: 36px; flex-wrap: wrap; margin-top: 14px; }
.home-logos-row img { height: 28px; width: auto; filter: grayscale(1); opacity: 0.55; }

/* === TOUR === */
.home-tour { padding: 80px 0; background: var(--paper); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
.home-tour h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); color: var(--ink); margin-bottom: 14px; }
.home-tour h2 em { font-style: italic; color: var(--stream); }
.home-tour-lede { font-size: 1.05rem; color: var(--ink-soft); line-height: 1.65; max-width: 600px; margin-bottom: 40px; }
.home-tour-flow { display: flex; flex-direction: column; gap: 20px; }
.home-tour-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.home-tour-card { background: var(--cream); border: 1px solid var(--rule); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; }
.home-tour-card-vis { padding: 16px; background: var(--paper); border-top: 1px solid var(--rule); min-height: 170px; margin-top: auto; }
.home-tour-card-body { padding: 24px; }
.home-tour-card-label { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
.home-tour-card h3 { font-size: 1.15rem; color: var(--ink); margin-bottom: 10px; }
.home-tour-card p { font-size: 0.9rem; color: var(--ink-soft); line-height: 1.6; }
.home-tour-card--wide .home-tour-card-vis { display: flex; justify-content: center; min-height: auto; }
.home-tour-card--wide .home-tour-card-vis .demo-frame { max-width: 760px; }
.home-tour-card--wide .home-tour-card-body { padding: 32px 40px; max-width: 820px; }
.home-tour-callouts { margin-top: 20px; display: flex; flex-direction: column; gap: 6px; }
.home-tour-callout { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: var(--stream); letter-spacing: 0.02em; }
.home-tour-callout::before { content: '→ '; color: var(--accent); }

/* Mini visuals */
.huddle-mini { font-size: 0.72rem; }
.huddle-mini-tabs { display: flex; gap: 4px; margin-bottom: 10px; }
.huddle-mini-tab { padding: 4px 10px; border-radius: 100px; background: var(--paper-warm); color: var(--ink-mute); font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.05em; }
.huddle-mini-tab--active { background: var(--stream-light); color: var(--stream); }
.huddle-mini-row { padding: 8px 10px; border-bottom: 1px solid var(--rule); display: flex; justify-content: space-between; align-items: center; }
.huddle-mini-name { font-weight: 600; color: var(--ink-soft); font-size: 0.72rem; }
.huddle-mini-meta { color: var(--ink-mute); font-size: 0.62rem; }
.scratchpad-mock { font-family: 'Fraunces', Georgia, serif; font-style: italic; font-size: 0.85rem; color: var(--ink-soft); padding: 16px; border: 2px dashed var(--rule); border-radius: 8px; margin-bottom: 12px; line-height: 1.5; }
.scratchpad-arrow { text-align: center; color: var(--ink-mute); font-size: 1.2rem; margin: 8px 0; }
.scratchpad-result { padding: 12px; background: var(--stream-light); border-radius: 6px; font-size: 0.75rem; color: var(--stream-dark); }
.scratchpad-result-label { font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.08em; color: var(--stream); margin-bottom: 4px; }

/* === JAKE QUOTE === */
.home-quote { padding: 80px 0; background: var(--paper-warm); }
.home-quote-card { background: var(--stream-dark); border-radius: 20px; padding: 56px; max-width: 900px; margin: 0 auto; text-align: center; color: var(--cream); }
.home-quote blockquote { font-family: 'Fraunces', Georgia, serif; font-size: 1.6rem; font-style: italic; line-height: 1.45; color: var(--cream); margin-bottom: 28px; max-width: 720px; margin-left: auto; margin-right: auto; }
.home-quote blockquote em { font-style: normal; color: var(--accent-soft); }
.home-quote-attr { display: flex; align-items: center; gap: 14px; justify-content: center; }
.home-quote-avatar { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; object-position: center 20%; }
.home-quote-name { font-weight: 600; color: var(--cream); font-size: 0.95rem; }
.home-quote-title { font-size: 0.78rem; color: rgba(250,247,240,0.5); }
.home-quote-link { font-size: 0.78rem; color: var(--accent-soft); text-decoration: none; margin-top: 16px; display: inline-block; }
.home-quote-link:hover { text-decoration: underline; }
.home-quote-story { font-size: 0.9rem; color: rgba(250,247,240,0.6); max-width: 560px; margin: 0 auto 24px; line-height: 1.6; }

/* === FEATURES STRIP === */
.home-incl { padding: 40px 0; border-bottom: 1px solid var(--rule); }
.home-incl-line { font-size: 0.9rem; color: var(--ink-soft); line-height: 1.9; text-align: center; max-width: 820px; margin: 0 auto; }
.home-incl-label { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-mute); margin-right: 6px; }
.home-incl-line a { color: var(--stream); font-weight: 600; text-decoration: none; white-space: nowrap; }
.home-incl-line a:hover { text-decoration: underline; }

/* === METRICS === */
.home-metrics { padding: 64px 0; }
.home-metrics-grid { display: flex; justify-content: center; gap: 72px; flex-wrap: wrap; text-align: center; }
.home-metric-value { font-family: 'Fraunces', Georgia, serif; font-size: 2.8rem; line-height: 1.1; color: var(--stream-dark); margin-bottom: 6px; }
.home-metric-label { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-mute); max-width: 240px; margin: 0 auto; line-height: 1.6; }

/* === RESEARCH STRIP === */
.home-research { padding: 72px 0; background: var(--ink); color: var(--cream); }
.home-research-inner { max-width: 760px; margin: 0 auto; text-align: center; }
.home-research h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); color: var(--cream); margin-bottom: 20px; }
.home-research-body { font-size: 1rem; color: rgba(250,247,240,0.7); line-height: 1.7; margin-bottom: 20px; }
.home-research-body em { font-style: italic; color: rgba(250,247,240,0.9); }
.home-research-cite { font-size: 0.82rem; }
.home-research-cite a { color: rgba(250,247,240,0.4); text-decoration: none; border-bottom: 1px solid rgba(250,247,240,0.2); transition: color 0.12s; }
.home-research-cite a:hover { color: var(--accent-soft); }
.home-research-book { font-size: 0.92rem; margin-top: 24px; }
.home-research-book a { color: var(--accent-soft); text-decoration: none; border-bottom: 1px solid rgba(232,122,97,0.35); transition: border-color 0.12s; }
.home-research-book a:hover { border-color: var(--accent-soft); }

/* === REVENUE === */
.home-revenue { padding: 80px 0; background: var(--cream); }
.home-revenue h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); color: var(--ink); margin-bottom: 14px; }
.home-revenue h2 em { font-style: italic; color: var(--stream); }
.home-revenue-body { font-size: 1rem; color: var(--ink-soft); line-height: 1.7; max-width: 680px; margin-bottom: 36px; }
.home-rev-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
.home-rev-card { display: flex; flex-direction: column; gap: 8px; background: var(--cream); border: 1px solid var(--rule); border-radius: 16px; padding: 28px; text-decoration: none; transition: border-color 0.15s; }
.home-rev-card:hover { border-color: var(--stream); }
.home-rev-label { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-mute); }
.home-rev-card h3 { font-size: 1.05rem; color: var(--ink); }
.home-rev-more { font-size: 0.82rem; color: var(--stream); font-weight: 600; margin-top: auto; }

/* === TESTIMONIALS === */
.home-proof { padding: 80px 0; background: var(--paper); border-top: 1px solid var(--rule); }
.home-proof h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); color: var(--ink); margin-bottom: 40px; }
.home-proof h2 em { font-style: italic; color: var(--stream); }
.home-proof-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.home-proof-feature { background: var(--cream); border: 1px solid var(--rule); border-radius: 16px; padding: 28px; display: flex; flex-direction: column; }
.home-proof-feature blockquote { font-family: 'Fraunces', Georgia, serif; font-size: 1.1rem; color: var(--ink); line-height: 1.5; margin-bottom: 20px; }
.home-proof-attr { display: flex; align-items: center; gap: 12px; margin-top: auto; }
.home-proof-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--stream-light); color: var(--stream); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 600; flex-shrink: 0; }
.home-proof-name { font-weight: 600; color: var(--ink); font-size: 0.9rem; }
.home-proof-title { font-size: 0.78rem; color: var(--ink-mute); }

/* === PRICING === */
.home-pricing { padding: 80px 0; }
.home-pricing h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); color: var(--ink); margin-bottom: 14px; text-align: center; }
.home-pricing h2 em { font-style: italic; color: var(--stream); }
.home-pricing-lede { font-size: 1rem; color: var(--ink-soft); text-align: center; max-width: 560px; margin: 0 auto 40px; }
.home-pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 840px; margin: 0 auto; }
.home-price-card { border-radius: 16px; padding: 36px; border: 1px solid var(--rule); }
.home-price-card--primary { background: var(--stream-dark); color: var(--cream); border-color: var(--stream-dark); position: relative; overflow: hidden; }
.home-price-card--primary::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--accent); }
.home-price-card--secondary { background: var(--cream); }
.hp-label { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px; }
.home-price-card--primary .hp-label { color: var(--accent-soft); }
.home-price-card--secondary .hp-label { color: var(--ink-mute); }
.hp-badge { display: inline-block; background: var(--accent); color: var(--cream); font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; letter-spacing: 0.08em; padding: 3px 8px; border-radius: 100px; margin-left: 8px; vertical-align: middle; }
.hp-name { font-size: 0.95rem; font-weight: 500; margin-bottom: 16px; }
.home-price-card--primary .hp-name { color: rgba(250,247,240,0.7); }
.home-price-card--secondary .hp-name { color: var(--ink-soft); }
.hp-amount { font-family: 'Fraunces', Georgia, serif; font-size: 3rem; line-height: 1; margin-bottom: 4px; }
.hp-amount s { font-size: 1.5rem; opacity: 0.4; margin-right: 8px; }
.hp-per { font-size: 0.82rem; margin-bottom: 24px; }
.home-price-card--primary .hp-per { color: rgba(250,247,240,0.5); }
.home-price-card--secondary .hp-per { color: var(--ink-mute); }
.hp-features { list-style: none; display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px; }
.hp-features li { font-size: 0.85rem; display: flex; align-items: flex-start; gap: 8px; line-height: 1.4; }
.hp-features li::before { content: '✓'; color: var(--accent-soft); font-weight: 700; flex-shrink: 0; }
.home-price-card--secondary .hp-features li { color: var(--ink-soft); }
.home-price-card--secondary .hp-features li::before { color: var(--stream); }
.home-price-card--primary .hp-features li { color: rgba(250,247,240,0.75); }
.hp-trust { font-size: 0.76rem; color: rgba(250,247,240,0.35); text-align: center; margin-top: 12px; }
.hp-anchor { font-size: 0.88rem; color: var(--ink-soft); line-height: 1.55; margin-bottom: 24px; }
.hp-proof { font-size: 0.8rem; color: var(--ink-mute); font-style: italic; line-height: 1.55; border-left: 2px solid var(--stream-light); padding-left: 12px; margin-bottom: 24px; }

/* === FAQ === */
.home-faq { padding: 80px 0; background: var(--paper); border-top: 1px solid var(--rule); }
.home-faq h2 { font-size: clamp(1.6rem, 2.8vw, 2.2rem); color: var(--ink); margin-bottom: 8px; }
.home-faq-sub { font-size: 1rem; color: var(--ink-mute); margin-bottom: 32px; }
.home-faq-sub a { color: var(--stream); text-decoration: none; font-weight: 500; }
