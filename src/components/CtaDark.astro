---
const {
  primaryHref = 'https://stream.riverrecords.ai/onboard/stream-pro',
  primaryLabel = 'Try it on your next visit',
  secondaryHref,
  secondaryLabel,
  trust = 'hello@riverrecords.ai · We respond same day.',
} = Astro.props;
---
<div class="cta-dark reveal">
  <h2><slot /></h2>
  <p><slot name="body" /></p>
  <div class="cta-dark-actions">
    <a href={primaryHref} class="btn btn-white">{primaryLabel}</a>
    {secondaryHref && <a href={secondaryHref} class="btn btn-outline-white">{secondaryLabel}</a>}
  </div>
  <p class="cta-dark-trust">{trust}</p>
</div>
